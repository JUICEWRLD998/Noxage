# ─────────────────────────────────────────────────────────────
# Noxage — environment template
# Copy to .env / apps/web/.env.local and fill values.
# Never commit real secrets. Sepolia is a TESTNET — only ever use a
# throwaway key funded with FREE test ETH here, never a mainnet key.
# ─────────────────────────────────────────────────────────────

# ── Ethereum Sepolia ─────────────────────────────────────────
# SEPOLIA_RPC_URL  [optional for deploy — the public default below works]
#   The public endpoint is fine to start. For fewer rate-limit errors,
#   create a free dedicated endpoint:
#     Alchemy: https://dashboard.alchemy.com  (Apps → Create App → Ethereum Sepolia → copy HTTPS URL)
#     Infura:  https://app.infura.io          (Create API Key → Sepolia → copy HTTPS endpoint)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# DEPLOYER_PRIVATE_KEY  [REQUIRED to deploy]
#   A throwaway wallet's private key, funded with FREE Sepolia test ETH.
#   1. Create a fresh account in MetaMask (do NOT reuse a mainnet account).
#   2. Export its private key: MetaMask → Account → ⋮ → Account details → Show private key.
#   3. Fund it with test ETH from a faucet (need ~0.1 test ETH for these deploys):
#        Google Cloud:      https://cloud.google.com/application/web3/faucet/ethereum/sepolia
#        Alchemy:           https://sepoliafaucet.com
#        Infura:            https://www.infura.io/faucet/sepolia
#        PoW (no login):    https://sepolia-faucet.pk910.de
#   Format: 0x-prefixed 64 hex chars.
DEPLOYER_PRIVATE_KEY=0xYOUR_SEPOLIA_DEPLOYER_PRIVATE_KEY

# ETHERSCAN_API_KEY  [optional — only needed to verify contracts on Etherscan]
#   Free key: https://etherscan.io/apis  (sign in → API Keys → Add)
ETHERSCAN_API_KEY=

# ── Frontend (apps/web/.env.local) ───────────────────────────
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID  [needed for wallet connect in the app — Phase 5]
#   Free project id: https://dashboard.reown.com  (formerly cloud.walletconnect.com)
#   Create project → copy the Project ID.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract addresses (filled after Phase 2+ deploys)
NEXT_PUBLIC_NOXAGE_VAULT_ADDRESS=
NEXT_PUBLIC_NOXAGE_INTENT_BOOK_ADDRESS=
NEXT_PUBLIC_NOXAGE_EPOCH_MANAGER_ADDRESS=
NEXT_PUBLIC_NOXAGE_SETTLEMENT_EXECUTOR_ADDRESS=
NEXT_PUBLIC_NOXAGE_FILL_LEDGER_ADDRESS=

# Uniswap v3 router on Sepolia (unmodified public rail)
# Canonical SwapRouter02 (Sepolia): 0x3bFA4769FB09eefC5a80d6E87c3B9C650f7Ae48E
# Ref: https://docs.uniswap.org/contracts/v3/reference/deployments/ethereum-deployments
NEXT_PUBLIC_UNISWAP_V3_ROUTER_ADDRESS=

# ── Confidential balances: Zama FHEVM (Phase 2) ──────────────
# ERC-7984 confidential tokens run on Zama's FHEVM coprocessor, which is
# deployed & maintained by Zama on Sepolia. The on-chain ACL / Coprocessor /
# KMSVerifier addresses are wired automatically in-contract by block.chainid
# (see @fhevm/solidity ZamaConfig), so NO key/address env vars are needed here
# to deploy. Off-chain encrypt/decrypt (frontend, Phase 5) goes via the relayer:
#   Zama FHEVM docs: https://docs.zama.org/fhevm
NEXT_PUBLIC_FHEVM_RELAYER_URL=https://relayer.testnet.zama.cloud
NEXT_PUBLIC_FHEVM_NETWORK=sepolia

# Confidential wrapper addresses (filled by deploy-confidential.ts)
NEXT_PUBLIC_NOXAGE_CONFIDENTIAL_USDC_ADDRESS=
NEXT_PUBLIC_NOXAGE_CONFIDENTIAL_WETH_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=
NEXT_PUBLIC_MOCK_WETH_ADDRESS=

# ── iExec Nox TEE (Phase 4 — batch netting compute) ──────────
# Nox handles the off-chain TEE netting runner, NOT the confidential balances
# above. Endpoints / keys as documented by Nox (wired in Phase 4).
#   iExec docs: https://docs.iex.ec
NOX_GATEWAY_URL=
NOX_RUNNER_URL=
NEXT_PUBLIC_NOX_NETWORK=sepolia
